{
  "name": "al-shafi-backend",
  "version": "1.0.0",
  "description": "Backend API for Al-Shafi Healthcare Application",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "npx tsx src/app.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "db:check": "tsx src/scripts/db-check.ts",
    "db:status": "tsx src/scripts/db-status.ts",
    "db:setup": "npm run migrate && npm run db:check && npm run db:status"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.8.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.22",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
